{
  "name": "bundler",
  "version": "0.0.0",
  "description": "Tool to launch and build JavaScript/Frameworks. This tool automates polyfills for Edge Computing and assists in creating Workers, notably for the Azion platform.",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "lint:fix": "pnpm -r --if-present lint:fix",
    "format": "pnpm -r --if-present format",
    "format:check": "pnpm -r --if-present format:check",
    "test": "pnpm -r --if-present --workspace-concurrency=1 test"
  },
  "author": "aziontech",
  "license": "MIT",
  "dependencies": {
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.29.2",
    "@commitlint/cli": "^18.4.1",
    "@commitlint/config-conventional": "^18.4.0",
    "@eslint/js": "^9.36.0",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "conventional-changelog-conventionalcommits": "^4.6.0",
    "eslint": "^9.36.0",
    "globals": "^16.0.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-puppeteer": "^9.0.1",
    "pkg-pr-new": "^0.0.60",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.3.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aziontech/bundler.git"
  },
  "bugs": {
    "url": "https://github.com/aziontech/bundler/issues"
  },
  "homepage": "https://github.com/aziontech/bundler#readme"
}
